# Frigate connection
FRIGATE_URL=http://localhost:5000

# Google Cloud Vision (optional fallback classifier)
# Path to GCP service account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-credentials.json

# Label Studio
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_KEY=your-label-studio-api-key

# Database
DATABASE_URL=sqlite:///pipeline.db

# Pipeline settings (override config/pipeline.yaml)
# POLL_INTERVAL_MINUTES=15
# BATCH_TRIGGER_SIZE=200
# CLIP_DEVICE=cuda:0
